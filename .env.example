# ---------------------------------------------------------------------------
# Prep Tracker — environment variables (example)
# Copy this file to `.env.local` and fill in real values. NEVER commit secrets.
# ---------------------------------------------------------------------------

# MongoDB Atlas connection string (e.g. mongodb+srv://user:pass@cluster/db)
MONGODB_URI=

# Secret key used as the HMAC key for hashing session tokens before storage.
# Use a long random string (e.g. `openssl rand -base64 32`).
AUTH_SECRET=

# Single-owner credentials — used ONCE by `npm run seed` to provision the owner.
OWNER_USERNAME=
OWNER_EMAIL=
OWNER_PASSWORD=
